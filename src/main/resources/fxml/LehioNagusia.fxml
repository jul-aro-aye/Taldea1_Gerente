<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="kontrola.LehioNagusiaController"
            stylesheets="@estilo.css">

    <!-- 🔹 Barra lateral izquierda -->
    <left>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" styleClass="scroll-pane">
            <content>
                <VBox spacing="15" styleClass="left-vbox">

                    <!-- Logo / título -->
                    <Label text="JAUS" />

                    <Label text="" style="-fx-padding: 10 0 0 0;" />

                    <!-- Botones laterales -->
                    <Button fx:id="btnProduktuak" text="Produktuak" prefWidth="180"
                            onAction="#kargatuProduktuak" styleClass="left-button" />
                    <Button fx:id="btnKategoriak" text="Kategoriak" prefWidth="180"
                            onAction="#kargatuKategoriak" styleClass="left-button" />
                    <Button fx:id="btnMahaiak" text="Mahaiak" prefWidth="180"
                            onAction="#kargatuMahaiak" styleClass="left-button" />
                    <Button fx:id="btnErreserbak" text="Erreserbak" prefWidth="180"
                            onAction="#kargatuErreserbak" styleClass="left-button" />
                    <Button fx:id="btnErabiltzaileak" text="Erabiltzaileak" prefWidth="180"
                            onAction="#kargatuErabiltzaileak" styleClass="left-button" />
                    <Button fx:id="btnRolak" text="Rolak" prefWidth="180"
                            onAction="#kargatuRolak" styleClass="left-button" />
                    <Button fx:id="btnOsagaiak" text="Osagaiak" prefWidth="180"
                            onAction="#kargatuOsagaiak" styleClass="left-button" />

                    <!-- Relleno para que la barra llegue abajo -->
                    <Pane VBox.vgrow="ALWAYS" />

                </VBox>
            </content>
        </ScrollPane>
    </left>

    <!-- 🔹 Área central -->
    <center>
        <StackPane fx:id="contentArea">
            <Label text="Hemen agertuko da edukia"
                   style="-fx-font-size: 20px; -fx-text-fill: #555;" />
        </StackPane>
    </center>

</BorderPane>
