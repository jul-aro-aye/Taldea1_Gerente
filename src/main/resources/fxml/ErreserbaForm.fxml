<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="kontrola.ErreserbaFormController"
            prefWidth="360"
            prefHeight="360">
    <VBox spacing="10">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <Label text="Mahai zenbakia:"/>
        <ComboBox fx:id="cmbMahaia" promptText="Hautatu mahaia"/>

        <Label text="Bezeroa:"/>
        <TextField fx:id="txtBezeroa" promptText="Sartu bezeroaren izena"/>

        <Label text="Telefonoa:"/>
        <TextField fx:id="txtTelefonoa" promptText="Sartu telefonoa"/>

        <Label text="Erreserba data:"/>
        <DatePicker fx:id="dpErreserbaData"/>

        <Label text="Txanda:"/>
        <ComboBox fx:id="cmbTxanda" promptText="Hautatu txanda"/>

        <Label text="Pertsona kopurua:"/>
        <TextField fx:id="txtPertsonak" promptText="Adib. 4"/>

        <Label text="Egoera:"/>
        <ComboBox fx:id="cmbEgoera" promptText="Hautatu egoera"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="btnGorde" text="Gorde" onAction="#gordeErreserba"/>
            <Button fx:id="btnUtzi" text="Utzi" onAction="#itxi"/>
        </HBox>
    </VBox>
</AnchorPane>
