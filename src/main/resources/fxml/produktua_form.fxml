<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="kontrola.ProduktuaFormController"
      spacing="10">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>



    <GridPane hgap="10" vgap="10">
        <Label text="Izena:"/>
        <TextField fx:id="txtIzena"/>

        <Label text="Kategoria:" GridPane.rowIndex="1"/>
        <ComboBox fx:id="cmbKategoria" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Prezioa:" GridPane.rowIndex="2"/>
        <TextField fx:id="txtPrezioa" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Stock:" GridPane.rowIndex="3"/>
        <TextField fx:id="txtStock" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <Separator/>

    <Label text="Osagaiak:" style="-fx-font-weight: bold"/>

    <TextField fx:id="txtBilatuOsagaia" promptText="Bilatu osagaia..."/>

    <HBox spacing="10">
        <TableView fx:id="osagaiTaula" prefHeight="150">
            <columns>
                <TableColumn fx:id="colOsagaiaIzena" text="Osagaia"/>
                <TableColumn fx:id="colKantitatea" text="Kantitatea"/>
                <TableColumn fx:id="colUnitatea" text="Unitatea"/>
            </columns>
        </TableView>

        <VBox spacing="5">
            <Button text="➕ Gehitu" onAction="#gehituOsagaia"/>
            <Button text="❌ Kendu" onAction="#kenduOsagaia"/>
        </VBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Gorde" onAction="#gordeProduktua"/>
        <Button text="Utzi" onAction="#itxi"/>
    </HBox>
</VBox>
